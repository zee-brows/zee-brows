# Zee Brows production environment
# Copy this file to .env.local for local development and add the same values in Vercel Project Settings.

# Admin login for /admin
ADMIN_EMAIL=admin@zeebrows.com
ADMIN_PASSWORD=replace-with-a-long-secure-password

# Supabase database and storage
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=zee-brows-media

# Optional Cloudinary remote image support is enabled in next.config.mjs.
# If using Cloudinary directly, store uploaded asset URLs in the admin dashboard.
